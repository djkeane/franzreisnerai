# ═══════════════════════════════════════════════════
# FRANZ v6.0 — API kulcsok és konfiguráció
# Másold .env névre és töltsd ki!
# ═══════════════════════════════════════════════════

# ── Elsődleges LLM: Groq (gyors, kód) ──────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=llama3-70b-8192

# ── Másodlagos LLM: Google Gemini (HU, hosszú kontextus) ──
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL=gemini-1.5-pro

# ── Fallback LLM: OpenRouter ────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Cache (fájl alapú) ──────────────────────────────
CACHE_DIR=.cache
CACHE_TTL_HOURS=24

# ── API korlátok ────────────────────────────────────
MAX_TOKENS_PER_DAY=100000
MAX_REQUESTS_PER_MIN=20
MAX_AUTONOMOUS_ITERATIONS=50
SCRAPING_RATE_LIMIT_SEC=2

# ── Memória ─────────────────────────────────────────
CHROMA_DB_PATH=memory/chroma
STRUCTURED_DB_PATH=memory/knowledge.json
SHORT_TERM_TOKEN_LIMIT=4096

# ── Scraping ────────────────────────────────────────
USE_PLAYWRIGHT=false
PLAYWRIGHT_TIMEOUT_SEC=30

# ── Debug ───────────────────────────────────────────
FRANZ_DEBUG=false
LOG_LEVEL=INFO
